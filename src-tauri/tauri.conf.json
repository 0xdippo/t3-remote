{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "T3 Remote Air",
  "version": "0.1.0",
  "identifier": "gg.pingdot.remoteair",
  "build": {
    "frontendDist": "../vendor/t3code/apps/web/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "create": false,
        "title": "T3 Remote Air",
        "width": 1440,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 700,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
